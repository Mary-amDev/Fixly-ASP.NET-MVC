<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fixly</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Fixly.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header class="px-2 pt-2">
        <nav class="fixly-navbar">

            <a class="fixly-logo">
                <span class="logo-dot"></span>
                <span>Fixly</span>
            </a>

            <div class="fixly-menu">

                <a class="search-btn" asp-controller="" asp-action="">
                    Incoming Requests
                </a>

                <a class="menu-link" asp-controller="Profile" asp-action="Index">
                    Profile
                </a>

                <form asp-controller="Account" asp-action="" method="post">
                    <button type="submit" class="logout-btn">
                        Logout
                    </button>
                </form>

            </div>

        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Fixly - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>